{
  "name": "@hallelx/youtube-transcript",
  "version": "0.2.0",
  "description": "Fetch YouTube video transcripts and subtitles (manual and auto-generated) from Node.js, Bun, and Deno. TypeScript port of youtube-transcript-api.",
  "keywords": [
    "youtube",
    "transcript",
    "subtitles",
    "captions",
    "cc",
    "youtube-transcript",
    "youtube-captions",
    "typescript",
    "node",
    "bun",
    "deno"
  ],
  "license": "MIT",
  "author": "hallelx2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hallelx2/youtube-transcript-ts.git"
  },
  "bugs": {
    "url": "https://github.com/hallelx2/youtube-transcript-ts/issues"
  },
  "homepage": "https://github.com/hallelx2/youtube-transcript-ts#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "youtube-transcript": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "undici": ">=5"
  },
  "peerDependenciesMeta": {
    "undici": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.12.0",
    "eslint": "^9.39.4",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.1",
    "undici": "^6.18.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
